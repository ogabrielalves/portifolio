<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gabriel Alves | Software Developer</title>
    <meta name="description" content="Portfólio de Gabriel Alves — Software Developer especializado em Java, Spring Boot e APIs REST." />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Devicons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
    />

    <style>
      :root {
        --bg: #0a0a0a;
        --bg-card: #111111;
        --text: #ffffff;
        --text-muted: #888888;
        --accent: #ffffff;
        --border: #222222;
        --shadow: 0 18px 45px rgba(0, 0, 0, 0.45);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Outfit", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: radial-gradient(circle at top, rgba(255, 255, 255, 0.05), transparent 55%),
          linear-gradient(180deg, #0a0a0a 0%, #050505 100%);
        color: var(--text);
        overflow-x: hidden;
        cursor: none;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .container {
        width: min(1120px, 92vw);
        margin: 0 auto;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* Navbar */
      header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 99;
        backdrop-filter: blur(12px);
        background: rgba(10, 10, 10, 0.65);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.1rem 1.5rem;
      }

      .logo {
        display: inline-flex;
        gap: 0.5rem;
        align-items: center;
        font-family: "JetBrains Mono", monospace;
        font-weight: 800;
        font-size: 1.15rem;
        letter-spacing: 0.09rem;
        color: var(--text);
      }

      .nav-links {
        display: flex;
        gap: 1.6rem;
        align-items: center;
      }

      .nav-links a {
        position: relative;
        font-weight: 600;
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.85);
        transition: color 0.3s ease;
      }

      .nav-links a:hover {
        color: var(--text);
      }

      .nav-links a::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -0.25rem;
        width: 0;
        height: 2px;
        background: var(--accent);
        transition: width 0.3s ease;
      }

      .nav-links a:hover::after {
        width: 100%;
      }

      .btn-resume {
        border: 1px solid rgba(255, 255, 255, 0.4);
        padding: 0.55rem 1rem;
        border-radius: 999px;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
      }

      .btn-resume:hover {
        border-color: var(--accent);
        background: rgba(255, 255, 255, 0.08);
        transform: translateY(-1px);
      }

      .btn-resume svg {
        width: 1rem;
        height: 1rem;
        fill: currentColor;
      }

      .hamburger {
        display: none;
        width: 2rem;
        height: 2rem;
        border: none;
        background: transparent;
        cursor: pointer;
        align-items: center;
        justify-content: center;
      }

      .hamburger span,
      .hamburger span::before,
      .hamburger span::after {
        display: block;
        width: 1.35rem;
        height: 2px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.88);
        position: relative;
        transition: transform 0.3s ease, opacity 0.3s ease;
      }

      .hamburger span::before,
      .hamburger span::after {
        content: "";
        position: absolute;
        left: 0;
      }

      .hamburger span::before {
        top: -0.44rem;
      }

      .hamburger span::after {
        top: 0.44rem;
      }

      .nav-open .hamburger span {
        transform: rotate(45deg);
      }

      .nav-open .hamburger span::before {
        transform: rotate(90deg);
        top: 0;
      }

      .nav-open .hamburger span::after {
        opacity: 0;
      }

      .mobile-nav {
        position: fixed;
        inset: 0;
        padding: 6rem 1.5rem 2rem;
        display: none;
        flex-direction: column;
        gap: 1.3rem;
        background: rgba(10, 10, 10, 0.95);
        backdrop-filter: blur(18px);
      }

      .mobile-nav a {
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        color: rgba(255, 255, 255, 0.92);
      }

      .mobile-nav .btn-resume {
        width: fit-content;
        padding: 0.75rem 1.15rem;
      }

      .nav-open .mobile-nav {
        display: flex;
      }

      /* Hero */
      .hero {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: stretch;
        overflow: hidden;
      }

      .hero__content {
        position: relative;
        padding: 7.5rem 2.5rem 4.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1.2rem;
      }

      .hero__title {
        font-family: "DM Sans", sans-serif;
        font-size: clamp(2.8rem, 5vw, 5.5rem);
        line-height: 1.05;
        font-weight: 800;
        letter-spacing: -0.025em;
        margin: 0;
      }

      .hero__subtitle {
        font-family: "DM Sans", sans-serif;
        font-size: clamp(1.4rem, 3vw, 2.3rem);
        font-weight: 300;
        letter-spacing: 0.03em;
        margin: 0;
        color: rgba(255, 255, 255, 0.88);
      }

      .hero__text {
        max-width: 540px;
        font-size: 1.05rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.75);
      }

      .hero__social {
        display: flex;
        gap: 1rem;
        align-items: center;
      }

      .social-link {
        width: 2.4rem;
        height: 2.4rem;
        display: grid;
        place-items: center;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 0.85rem;
        transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
      }

      .social-link:hover {
        border-color: var(--accent);
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(-2px);
      }

      .social-link svg {
        width: 1.2rem;
        height: 1.2rem;
        fill: currentColor;
      }

      .hero__image {
        position: relative;
        display: grid;
        place-items: center;
        overflow: visible;
        background: #0a0a0a;
      }

      .hero__image img {
        width: 380px;
        height: 380px;
        border-radius: 50%;
        object-fit: cover;
        object-position: center top;
        filter: grayscale(100%) contrast(1.05) brightness(1.1);
        border: 2px solid rgba(255, 255, 255, 0.15);
        box-shadow: 0 8px 60px rgba(0, 0, 0, 0.6);
      }

      /* Section base */
      section {
        padding: 6rem 0;
      }

      .section-title {
        font-family: "DM Sans", sans-serif;
        font-size: clamp(2.3rem, 4vw, 3.2rem);
        font-weight: 800;
        letter-spacing: -0.015em;
        margin: 0 0 1.2rem;
      }

      .section-subtitle {
        font-size: 1.05rem;
        color: rgba(255, 255, 255, 0.7);
        max-width: 740px;
        line-height: 1.7;
        margin: 0 0 2.5rem;
      }

      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 1.1rem;
        box-shadow: var(--shadow);
        padding: 1.8rem;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
      }

      .card:hover {
        transform: translateY(-6px);
        border-color: var(--accent);
        box-shadow: 0 30px 65px rgba(0, 0, 0, 0.55);
      }

      .fade-in {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.85s ease, transform 0.85s ease;
      }

      .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* About (code) */
      .code-window {
        border: 1px solid #30363d;
        border-radius: 1rem;
        background: #0d1117;
        overflow: hidden;
        font-family: "JetBrains Mono", monospace;
        box-shadow: 0 28px 60px rgba(0, 0, 0, 0.6);
      }

      .code-tab {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.9rem 1.2rem;
        background: rgba(18, 20, 24, 0.85);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .code-tab span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.22rem 0.7rem;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 600;
        background: rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.65);
      }

      .code-tab span:first-child {
        background: rgba(255, 255, 255, 0.1);
        color: #ffffff;
        font-weight: 700;
      }

      .code-tab .close {
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.16);
        position: relative;
      }

      .code-tab .close::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: radial-gradient(circle at center, rgba(255, 255, 255, 0.4), transparent 55%);
      }

      .code-block {
        padding: 1.6rem 1.5rem 2.2rem;
        overflow-x: auto;
        font-size: 0.95rem;
        line-height: 1.52;
        color: rgba(255, 255, 255, 0.92);
      }

      .code-block .token--keyword {
        color: #c084fc;
      }

      .code-block .token--class {
        color: #facc15;
      }

      .code-block .token--type {
        color: #60a5fa;
      }

      .code-block .token--method {
        color: #fde68a;
      }

      .code-block .token--variable {
        color: #ffffff;
      }

      .code-block .token--operator {
        color: #ffffff;
      }

      .code-block .token--string {
        color: #4ade80;
      }

      .code-block .token--number {
        color: #fdba74;
      }

      .code-block .token--comment {
        color: #6b7280;
      }

      .code-block .token--builtin {
        color: #7dd3fc;
      }

      .code-block .token--bracket {
        color: #fb923c;
      }

      /* Experience */
      .timeline {
        position: relative;
        padding-left: 1.5rem;
        margin-top: 2.5rem;
      }

      .timeline::before {
        content: "";
        position: absolute;
        left: 1.15rem;
        top: 0;
        bottom: 0;
        width: 4px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.05));
        border-radius: 999px;
      }

      .timeline-item {
        position: relative;
        padding: 1.6rem 1.8rem 1.8rem 2.75rem;
        margin-bottom: 2.1rem;
        border-radius: 1.2rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: transform 0.3s ease, border-color 0.3s ease;
      }

      .timeline-item::before {
        content: "";
        position: absolute;
        left: 0.9rem;
        top: 1.62rem;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: radial-gradient(circle at top left, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.1));
        box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.08);
      }

      .timeline-item:hover {
        border-color: rgba(255, 255, 255, 0.3);
        transform: translateY(-2px);
      }

      .timeline-item h4 {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 800;
      }

      .timeline-item .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1.1rem;
        margin: 0.4rem 0 1.1rem;
        color: rgba(255, 255, 255, 0.65);
        font-size: 0.95rem;
      }

      .timeline-item p {
        margin: 0;
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.65;
      }

      .timeline-item .tag {
        display: inline-flex;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        background: rgba(96, 165, 250, 0.1);
        border: 1px solid rgba(96, 165, 250, 0.2);
        font-size: 0.8rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.88);
      }

      /* Skills */
      .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(175px, 1fr));
        gap: 1.3rem;
      }

      .skill-card {
        padding: 1.55rem 1.25rem;
        border-radius: 1.1rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(18, 20, 25, 0.72);
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.35);
        transition: transform 0.25s ease, border-color 0.25s ease;
      }

      .skill-card:hover {
        transform: translateY(-4px);
        border-color: rgba(255, 255, 255, 0.3);
      }

      .skill-card .skill-head {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        margin-bottom: 1.2rem;
      }

      .skill-card .skill-icon {
        display: grid;
        place-items: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.85rem;
        background: rgba(255, 255, 255, 0.08);
        font-size: 1.1rem;
      }

      .skill-card .skill-title {
        font-weight: 700;
        letter-spacing: 0.01em;
        margin: 0;
        font-size: 0.95rem;
      }

      .progress {
        height: 0.5rem;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 999px;
        overflow: hidden;
      }

      .progress > div {
        height: 100%;
        background: linear-gradient(90deg, rgba(96, 165, 250, 0.9), rgba(96, 165, 250, 0.4));
        border-radius: 999px;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.7s ease;
      }

      .progress[data-visible="true"] > div {
        transform: scaleX(1);
      }

      /* Projects */
      .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
      }

      .project-card {
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(15, 15, 15, 0.85);
        border-radius: 1.2rem;
        padding: 1.6rem;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
        transition: transform 0.25s ease, border-color 0.25s ease;
      }

      .project-card:hover {
        transform: translateY(-3px);
        border-color: rgba(255, 255, 255, 0.3);
      }

      .project-card h4 {
        margin: 0 0 0.6rem;
        font-size: 1.25rem;
        font-weight: 800;
      }

      .project-card p {
        margin: 0 0 1rem;
        color: rgba(255, 255, 255, 0.72);
      }

      .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        margin-bottom: 1rem;
      }

      .project-tag {
        font-size: 0.75rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .project-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.88);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
      }

      .project-link:hover {
        border-color: rgba(255, 255, 255, 0.4);
        background: rgba(255, 255, 255, 0.05);
        transform: translateY(-1px);
      }

      .project-link svg {
        width: 1rem;
        height: 1rem;
      }

      /* Freelance Projects */
      .freelance-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
      }

      .freelance-card {
        background: linear-gradient(135deg, #0f0f0f, #1a1a2e);
        border: 1px solid #222222;
        border-radius: 1.2rem;
        padding: 2rem;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
        transition: transform 0.3s ease, border-color 0.3s ease;
      }

      .freelance-card:hover {
        transform: translateY(-4px);
        border-color: rgba(255, 255, 255, 0.3);
      }

      .freelance-card .icon-box {
        width: 56px;
        height: 56px;
        border-radius: 0.85rem;
        display: grid;
        place-items: center;
        font-size: 28px;
        margin-bottom: 1.5rem;
      }

      .freelance-card h4 {
        margin: 0 0 0.8rem;
        font-size: 1.35rem;
        font-weight: 800;
        color: #ffffff;
      }

      .freelance-card > p {
        margin: 0 0 1.2rem;
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.6;
        font-size: 0.95rem;
      }

      .freelance-features {
        margin-bottom: 1.5rem;
      }

      .freelance-features p {
        margin: 0 0 0.6rem;
        font-weight: 700;
        color: #ffffff;
        font-size: 0.9rem;
      }

      .freelance-features ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .freelance-features li {
        margin-bottom: 0.5rem;
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.9rem;
      }

      .freelance-features li::before {
        content: "• ";
        color: #60a5fa;
        font-weight: bold;
        margin-right: 0.5rem;
      }

      .freelance-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
      }

      .freelance-tag {
        display: inline-block;
        padding: 0.4rem 0.8rem;
        background: #1a1a1a;
        border: 1px solid #333333;
        border-radius: 999px;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.85);
        transition: border-color 0.3s ease;
      }

      .freelance-card:hover .freelance-tag {
        border-color: #60a5fa;
      }

      /* Contact */
      .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
      }

      .contact-card {
        background: rgba(16, 16, 16, 0.75);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1.15rem;
        padding: 1.8rem;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
      }

      .contact-card h3 {
        margin: 0 0 0.5rem;
        font-size: 1.5rem;
        font-weight: 700;
      }

      .contact-card a {
        color: rgba(255, 255, 255, 0.85);
        font-weight: 600;
        text-decoration: none;
      }

      .contact-card a:hover {
        color: var(--accent);
      }

      .social-grid {
        display: flex;
        gap: 1rem;
        margin-top: 1.4rem;
      }

      /* Custom cursor */
      #cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.7);
        pointer-events: none;
        transform: translate(-50%, -50%) scale(0.9);
        transition: transform 0.15s ease-out, background 0.15s ease-out;
        z-index: 9999;
        mix-blend-mode: difference;
      }

      .cursor--hover {
        transform: translate(-50%, -50%) scale(1.4);
        background: rgba(255, 255, 255, 1);
      }

      /* Footer */
      footer {
        padding: 4rem 0 2.5rem;
        text-align: center;
        color: rgba(255, 255, 255, 0.55);
        font-size: 0.9rem;
      }

      footer a {
        color: rgba(255, 255, 255, 0.7);
      }

      footer a:hover {
        color: var(--accent);
      }

      /* Responsive */
      @media (max-width: 960px) {
        .hero {
          grid-template-columns: 1fr;
          min-height: 100vh;
        }

        .hero__image {
          height: 55vh;
        }

        .hero__content {
          padding: 6rem 1.6rem 3.5rem;
        }

        .nav-links {
          display: none;
        }

        .hamburger {
          display: flex;
        }
      }

      @media (max-width: 520px) {
        .hero__image {
          height: 48vh;
        }

        .hero__text {
          font-size: 1rem;
        }

        .section-title {
          font-size: 2.2rem;
        }

        .code-block {
          font-size: 0.9rem;
        }

        .timeline {
          padding-left: 1rem;
        }

        .timeline::before {
          left: 1rem;
        }

        .timeline-item {
          padding-left: 2.5rem;
        }
      }
    </style>
  </head>

  <body>
    <div id="cursor" aria-hidden="true"></div>

    <header>
      <nav class="nav container" aria-label="Main navigation">
        <a class="logo" href="#hero" aria-label="Início">
          <span>GA</span>
        </a>

        <div class="nav-links" aria-hidden="true">
          <a href="#about">Sobre</a>
          <a href="#experience">Experiência</a>
          <a href="#skills">Skills</a>
        </div>

